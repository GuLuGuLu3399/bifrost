# Bifrost Monorepo .gitignore
# Language: Go + Rust + gRPC/Proto + Docker + Windows

############################
# OS / Editor
############################
.DS_Store
Thumbs.db
.vscode/
.idea/
.history/
*.code-workspace

############################
# Secrets / Config
############################
.env
.env.*
*.key
*.pem
*.p12
*.cer
*.crt
*.cert
!.env.example

############################
# Logs & Temp
############################
logs/
*.log
tmp/
temp/

############################
# Docker / Containers
############################
# Local bind-mount data (if present)
postgres_data/
redis_data/
# Compose overrides (local only)
docker-compose.override.yml

############################
# Go
############################
# Binaries & test outputs
*.exe
*.out
*.test
*.prof
*.pprof
coverage*
*.coverprofile
cover.out
# Local build outputs under services
go_services/**/bin/

############################
# Rust
############################
# Workspace build outputs
rust_services/target/
# Per-crate target directories (defensive)
rust_services/**/target/
# Local service data (e.g., Oracle DuckDB)
rust_services/**/data/
rust_services/**/*.db
# Backup files
*.rs.bk

############################
# General build artifacts
############################
dist/
build/
out/
*.dll
*.so
*.dylib

############################
# Node (if web present later)
############################
web/node_modules/
web/.next/
web/dist/

############################
# Apps (Nuxt/Node) - Horizon & future apps
############################
# Common Nuxt/Nitro outputs
apps/**/.nuxt
apps/**/.nitro
apps/**/.output
apps/**/.cache
apps/**/.data
# Node dependencies
apps/**/node_modules/
# Build outputs & logs (defensive)
apps/**/dist
apps/**/logs
# IDE-specific
apps/**/.fleet
apps/**/.idea

############################
# Frontend apps (Helm, Horizon)
############################
# Common Nuxt/Vite outputs
frontend/apps/**/.nuxt
frontend/apps/**/.nitro
frontend/apps/**/.output
frontend/apps/**/.cache
frontend/apps/**/.data
frontend/apps/**/dist
frontend/apps/**/dist-ssr
frontend/apps/**/.vite
# Node dependencies and logs
frontend/apps/**/node_modules/
frontend/apps/**/logs
frontend/apps/**/npm-debug.log*
frontend/apps/**/yarn-debug.log*
frontend/apps/**/yarn-error.log*
frontend/apps/**/pnpm-debug.log*
frontend/apps/**/lerna-debug.log*
# Misc editor/project files
frontend/apps/**/.fleet
frontend/apps/**/.idea
frontend/apps/**/.vscode/
frontend/apps/**/.DS_Store
frontend/apps/**/.env
frontend/apps/**/.env.*
!frontend/apps/**/.env.example
frontend/apps/**/*.local
frontend/apps/**/*.suo
frontend/apps/**/*.ntvs*
frontend/apps/**/*.njsproj
frontend/apps/**/*.sln
frontend/apps/**/*.sw?
frontend/apps/**/src-tauri/target/

# Frontend workspace root
frontend/node_modules/
frontend/**/node_modules/
frontend/.turbo/
frontend/**/dist
frontend/**/.eslintcache

############################
# Proto / Generated Code
############################
# NOTE: We intentionally DO NOT ignore *.pb.go because they are tracked.
# If a separate gen directory is used later, uncomment:
# api/gen/

############################
# Misc
############################
# Avoid committing editor swap files and backups
*~
*.swp
*.swo
