{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["@types/node", "@vueuse/core"],
    // Note: "preserve" is valid in TypeScript 5.4+, but some VS Code extensions
